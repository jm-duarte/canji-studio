# Copie este arquivo para .env.local e preencha com suas credenciais do Sanity
# Para criar um projeto Sanity: https://www.sanity.io/manage

NEXT_PUBLIC_SANITY_PROJECT_ID=seu_project_id_aqui
NEXT_PUBLIC_SANITY_DATASET=production

# Opcional: token para acesso à API com permissões de escrita (ex: para mutations server-side)
# SANITY_API_TOKEN=seu_token_aqui
